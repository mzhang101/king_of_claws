# King of Claws — Environment Variables
# Copy this file to .env and modify as needed

# Server port (default: 3001)
PORT=3001

# Public URL — IMPORTANT: set this to your server's public address
# This is shown to users as the MCP connection URL for OpenClaw agents
# Examples:
#   LOCAL:  http://localhost:3001
#   CLOUD:  http://your-server-ip:3001
#   DOMAIN: https://claws.yourdomain.com
PUBLIC_URL=http://localhost:3001

# Server bind host (default: 0.0.0.0 for all interfaces)
# HOST=0.0.0.0
